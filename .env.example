# ──────────────────────────────────────────────
# BANCO DE DADOS (Neon ou Supabase)
# ──────────────────────────────────────────────
# Neon: https://neon.tech
# Supabase: https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/exclusive_multimarcas?sslmode=require"

# ──────────────────────────────────────────────
# NEXTAUTH / AUTH.JS
# ──────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aleatoria-minimo-32-chars"
# Em produção, usar o domínio real:
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# CLOUDINARY (upload de imagens)
# ──────────────────────────────────────────────
# Criar conta em: https://cloudinary.com
# Em Settings > Upload: criar preset "unsigned" chamado "exclusive_uploads"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="seu-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="exclusive_uploads"
